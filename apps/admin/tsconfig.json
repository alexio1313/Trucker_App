{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@truck-platform/shared": ["../../packages/shared/src"],
      "@truck-platform/api-client": ["../../packages/api-client/src"],
      "@truck-platform/state": ["../../packages/state/src"],
      "@truck-platform/ui-kit": ["../../packages/ui-kit/src"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}

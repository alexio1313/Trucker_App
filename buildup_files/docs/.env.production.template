# ──────────────────────────────────────────────────────────────
# TruckPlatform Production Environment Template
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to version control.
# ──────────────────────────────────────────────────────────────

# ─── Docker image registry ────────────────────────────────────
REGISTRY=ghcr.io/YOUR_GITHUB_ORG
IMAGE_TAG=latest

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=truckadmin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=truckplatform

# ─── MongoDB ──────────────────────────────────────────────────
MONGO_USER=truckadmin
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_USER=truckadmin
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── JWT (generate with: openssl rand -hex 64) ────────────────
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_HEX

# ─── AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Maps ──────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ─── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

# ─── Twilio (SMS OTP) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+1...

# ─── FCM (Push Notifications) ─────────────────────────────────
FCM_SERVER_KEY=CHANGE_ME

# ─── AWS S3 (KYC document storage) ───────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=ap-south-1
AWS_S3_BUCKET=truck-platform-kyc-docs

# ─── Social Publishing ────────────────────────────────────────
TWITTER_API_KEY=CHANGE_ME
TWITTER_API_SECRET=CHANGE_ME
LINKEDIN_CLIENT_ID=CHANGE_ME
LINKEDIN_CLIENT_SECRET=CHANGE_ME

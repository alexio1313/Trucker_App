# =============================================================
# AI TRUCK LOGISTICS PLATFORM - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# =============================================================

# ==================== DATABASE ====================
DB_PASSWORD=dev_password_change_in_prod
MONGO_PASSWORD=dev_password_change_in_prod

# ==================== AUTH ====================
JWT_SECRET=dev_secret_change_in_prod_min_32_chars_here
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# ==================== APP ====================
NODE_ENV=development
LOG_LEVEL=debug

# ==================== EXTERNAL APIs ====================
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
CLAUDE_API_KEY=your_anthropic_key_here
STRIPE_SECRET_KEY=your_stripe_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ==================== SMS / NOTIFICATIONS ====================
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# FCM (Firebase Cloud Messaging for push notifications)
FCM_SERVER_KEY=your_fcm_server_key
FCM_PROJECT_ID=your_firebase_project_id

# Email (SendGrid or SMTP)
SENDGRID_API_KEY=your_sendgrid_key
FROM_EMAIL=noreply@truckplatform.com
FROM_NAME=Truck Platform

# ==================== SOCIAL MEDIA ====================
FACEBOOK_APP_ID=your_fb_app_id
FACEBOOK_APP_SECRET=your_fb_secret
INSTAGRAM_ACCESS_TOKEN=your_ig_token
TWITTER_API_KEY=your_twitter_key
TWITTER_API_SECRET=your_twitter_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
LINKEDIN_CLIENT_ID=your_li_client_id
LINKEDIN_CLIENT_SECRET=your_li_secret
LINKEDIN_ACCESS_TOKEN=your_li_access_token
WHATSAPP_BUSINESS_TOKEN=your_wa_token
WHATSAPP_PHONE_NUMBER_ID=your_wa_phone_id

# ==================== MESSAGE QUEUES ====================
RABBITMQ_PASS=guest

# ==================== MONITORING ====================
GRAFANA_PASSWORD=admin
SENTRY_DSN=your_sentry_dsn_optional

# ==================== FEATURE FLAGS ====================
ENABLE_AI_PRICING=true
ENABLE_FRAUD_DETECTION=true
ENABLE_SOCIAL_PUBLISHING=true
ENABLE_OLLAMA_FALLBACK=true
ENABLE_BLOCKADE_DETECTION=true
ENABLE_SURGE_PRICING=true

# ==================== PAYMENT ====================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ==================== FILE STORAGE (AWS S3) ====================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
S3_BUCKET_KYC=truck-platform-kyc-docs
S3_BUCKET_LOADS=truck-platform-load-photos
S3_BUCKET_INVOICES=truck-platform-invoices

# ==================== TRAFFIC / ROUTING APIs ====================
TRAVELTIME_APP_ID=your_traveltime_app_id
TRAVELTIME_API_KEY=your_traveltime_api_key
HERE_MAPS_API_KEY=your_here_maps_key

# ==================== FUEL PRICE API ====================
FUEL_PRICE_API_KEY=your_fuel_price_api_key

# ==================== PLATFORM CONFIG ====================
PLATFORM_COMMISSION_PERCENT=5
MAX_SURGE_MULTIPLIER=1.5
WAITING_CHARGE_PER_MINUTE=10
GEOFENCE_RADIUS_METERS=500
GPS_UPDATE_INTERVAL_SECONDS=5
